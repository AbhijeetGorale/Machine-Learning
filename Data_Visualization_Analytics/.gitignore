# Ignore Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl

# Ignore virtual environments
venv/
env/
.venv/
ENV/

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore logs and temporary files
*.log
*.tmp
*.swp

# Ignore system files
.DS_Store
Thumbs.db

# Ignore dataset files (keep only sample or small demo data)
*.csv
*.xlsx
*.json

# Ignore reports and outputs
*.pdf
*.html
*.png
*.jpg
*.jpeg

# Ignore IDE/project settings
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Ignore requirements lock files (optional)
requirements.lock
